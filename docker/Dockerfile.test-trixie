# syntax=docker/dockerfile:1.7
# Test image for pg_pinyin on PostgreSQL 18 (Debian trixie)
ARG BASE_IMAGE=postgres:18.4-trixie
FROM ${BASE_IMAGE}

ARG DEBIAN_FRONTEND=noninteractive
ARG PG_SEARCH_VERSION=0.24.0
ARG DEBIAN_MIRROR=
ARG DEBIAN_SECURITY_MIRROR=
ARG PGDG_MIRROR=
ARG RUSTUP_DIST_SERVER=
ARG RUSTUP_UPDATE_ROOT=
ARG CARGO_REGISTRIES_CRATES_IO_INDEX=
ARG RUST_TOOLCHAIN=stable
ARG PGRX_VERSION=0.17.0

ENV CARGO_HOME=/cargo-home \
    RUSTUP_HOME=/rustup \
    PGRX_HOME=/pgrx \
    CARGO_TARGET_DIR=/cargo-target \
    CARGO_REGISTRIES_CRATES_IO_PROTOCOL=sparse \
    CARGO_NET_GIT_FETCH_WITH_CLI=true \
    RUSTUP_INIT_SKIP_PATH_CHECK=yes \
    PATH=/cargo-home/bin:$PATH

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
  --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
  set -eux; \
  if [ -n "$DEBIAN_MIRROR" ]; then \
    find /etc/apt -type f \( -name '*.list' -o -name '*.sources' \) -exec \
      sed -i \
        -e "s|http://deb.debian.org/debian|$DEBIAN_MIRROR|g" \
        -e "s|https://deb.debian.org/debian|$DEBIAN_MIRROR|g" \
        {} +; \
  fi; \
  if [ -n "$DEBIAN_SECURITY_MIRROR" ]; then \
    find /etc/apt -type f \( -name '*.list' -o -name '*.sources' \) -exec \
      sed -i \
        -e "s|http://deb.debian.org/debian-security|$DEBIAN_SECURITY_MIRROR|g" \
        -e "s|https://deb.debian.org/debian-security|$DEBIAN_SECURITY_MIRROR|g" \
        {} +; \
  fi; \
  if [ -n "$PGDG_MIRROR" ]; then \
    find /etc/apt -type f \( -name '*.list' -o -name '*.sources' \) -exec \
      sed -i \
        -e "s|http://apt.postgresql.org/pub/repos/apt|$PGDG_MIRROR|g" \
        -e "s|https://apt.postgresql.org/pub/repos/apt|$PGDG_MIRROR|g" \
        {} +; \
  fi; \
  apt-get update; \
  apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    git \
    curl \
    python3 \
    python3-venv \
    pkg-config \
    clang \
    llvm-dev \
    libc6-dev \
    make \
    python3-psycopg \
    pgtap \
    libpq5 \
    libpq-dev \
    postgresql-18 \
    postgresql-client-18 \
    postgresql-18-pgtap \
    postgresql-server-dev-18; \
  ARCH="$(dpkg --print-architecture)"; \
  case "$ARCH" in amd64|arm64) ;; *) echo "unsupported architecture for pg_search: $ARCH" >&2; exit 1 ;; esac; \
  PG_SEARCH_DEB="postgresql-18-pg-search_${PG_SEARCH_VERSION}-1PARADEDB-trixie_${ARCH}.deb"; \
  curl -fsSL -o "/tmp/${PG_SEARCH_DEB}" \
    "https://github.com/paradedb/paradedb/releases/download/v${PG_SEARCH_VERSION}/${PG_SEARCH_DEB}"; \
  apt-get install -y --no-install-recommends "/tmp/${PG_SEARCH_DEB}"; \
  update-ca-certificates; \
  rm -rf /var/lib/apt/lists/* /tmp/*

RUN --mount=type=cache,target=/cargo-home/registry,sharing=locked \
  --mount=type=cache,target=/cargo-home/git,sharing=locked \
  --mount=type=cache,target=/rustup/downloads,sharing=locked \
  set -eux; \
  mkdir -p "$CARGO_HOME" "$RUSTUP_HOME" "$PGRX_HOME" "$CARGO_TARGET_DIR"; \
  if [ -n "$RUSTUP_DIST_SERVER" ]; then export RUSTUP_DIST_SERVER; fi; \
  if [ -n "$RUSTUP_UPDATE_ROOT" ]; then export RUSTUP_UPDATE_ROOT; fi; \
  if [ -n "$CARGO_REGISTRIES_CRATES_IO_INDEX" ]; then export CARGO_REGISTRIES_CRATES_IO_INDEX; fi; \
  curl https://sh.rustup.rs -sSf | sh -s -- -y --profile minimal; \
  rustup default "${RUST_TOOLCHAIN}"; \
  rustup component add rustfmt clippy; \
  cargo install --locked cargo-pgrx --version "${PGRX_VERSION}"; \
  cargo --version; \
  rustc --version; \
  cargo pgrx --version; \
  chmod -R a+rwx "$CARGO_HOME" "$RUSTUP_HOME" "$PGRX_HOME" "$CARGO_TARGET_DIR"

WORKDIR /work
COPY . /work
